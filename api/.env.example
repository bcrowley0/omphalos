# Copy to api/.env and fill in. api/.env is gitignored and must NEVER be committed.
# Secrets live ONLY in this process (CLAUDE.md hard rule #2). Frontend never sees them.

# --- FRED (Phase 2: yield curve / macro) ---
FRED_API_KEY=

# --- Kraken private (Phase 3: balances) ---
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# --- IBKR Client Portal Gateway (Phase 5) ---
# Local gateway REST base; self-signed cert (TLS verification disabled for localhost only).
IBKR_GATEWAY_BASE_URL=https://localhost:5000/v1/api
